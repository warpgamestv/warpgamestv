# Cloudflare Pages — balance freshness vs repeat-visit speed (query ?v= still busts on deploy).
/js/*
  Cache-Control: public, max-age=300, must-revalidate

/css/*
  Cache-Control: public, max-age=300, must-revalidate

/lumen-clash/js/*
  Cache-Control: public, max-age=300, must-revalidate

/lumen-clash/css/*
  Cache-Control: public, max-age=300, must-revalidate
