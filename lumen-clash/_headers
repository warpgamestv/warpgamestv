# Cloudflare Pages — short TTL so browsers pick up new game.js/style.css after deploy.
# Use the block that matches your Pages “build output” root (site root vs /lumen-clash/).
/js/*
  Cache-Control: public, max-age=0, must-revalidate

/css/*
  Cache-Control: public, max-age=0, must-revalidate

/lumen-clash/js/*
  Cache-Control: public, max-age=0, must-revalidate

/lumen-clash/css/*
  Cache-Control: public, max-age=0, must-revalidate
